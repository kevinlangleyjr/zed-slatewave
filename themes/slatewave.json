        "border": "#1e293b",
        "border.variant": "#334155",
        "border.focused": "#5eead4",
        "border.selected": "#5eead4",
        "border.transparent": "#00000000",
        "border.disabled": "#334155",

        "elevated_surface.background": "#1e293b",
